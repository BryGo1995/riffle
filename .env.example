# Postgres
POSTGRES_USER=riffle
POSTGRES_PASSWORD=riffle
POSTGRES_DB=riffle
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000

# API / Pipeline
DATABASE_URL=postgresql+psycopg2://riffle:riffle@postgres:5432/riffle
USGS_API_KEY=

# Prefect (self-hosted locally via docker compose — no config needed)
#
# The compose stack runs its own Prefect server inside Docker. Leave the vars
# below UNSET for local dev — docker-compose.yml defaults PREFECT_API_URL to
# http://prefect-server:4200/api via internal DNS, which only resolves inside
# the compose network.
#
# To run `prefect` CLI commands from your HOST shell (not from inside the
# container), export this explicitly each invocation — the Docker-internal
# name does NOT resolve from the host:
#   PREFECT_API_URL=http://localhost:4200/api prefect deployment ls
#
# To point at Prefect Cloud instead of the bundled server (e.g. for a Railway
# production deploy), uncomment and fill in:
# PREFECT_API_URL=https://api.prefect.cloud/api/accounts/<id>/workspaces/<id>
