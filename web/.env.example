# Frontend dev environment variables.
# Copy this file to .env.local and edit as needed (Next.js auto-loads .env.local).

# Base URL for the FastAPI backend. Used when NEXT_PUBLIC_USE_MOCK is unset/0.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Set to 1 to render the app from in-repo mock data (web/lib/mocks.ts) and skip
# all backend calls. Use this for frontend-only development with no Docker /
# Postgres / Prefect required. Edit web/lib/mocks.ts to test edge cases
# (empty forecasts, null conditions, extreme flow values, etc.).
NEXT_PUBLIC_USE_MOCK=0
